<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin Airdrop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/main_styles_tiankawards.css">
</head>
<!--body class="gradient-bg" -->

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-light bg-light sticky-top navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="#">
            <i class="bi bi-wallet2"></i> TonkiApp Dashboard
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link active" href="/admin_dashboard">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/logout">
                        <i class="bi bi-box-arrow-right"></i> Salir
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="card text-center">
                <div class="card-body">
                    <h2 class="card-title">Airdrop</h2>
                    <p class="lead">Rewards for your most active users</p>
                    <div class="my-3" style="margin-top: 35px;">
                        <h5>Amount:</h5>
                        <p class="fs-3">{{ amount }}</p>
                        <p class="mb-1"><strong>Airdrop Wallet:</strong></p>
                        <p class="fs-6">{{ source_public_key }}</p>
                    </div>

                    <div class="my-3">
                        <p><strong>Scheduled Date:</strong> {{ scheduled_date }}</p>
                        <p><strong>Max Users:</strong> {{ max_users }}</p>
                        <p><strong>Periodicity (months):</strong> {{ periodicity_months }}</p>
                    </div>

                    <div class="d-flex justify-content-center mt-4">
                        <div class="d-grid gap-3 d-md-block">
                            <a href="" class="btn btn-outline-warning">
                                <i class="bi bi-cash-stack"></i> Add Funds
                            </a>
                            <a href="/send_airdrop" class="btn btn-outline-warning">
                                <i class="bi bi-send-check"></i> Deploy Airdrop
                            </a>
                            <a href="/configure_airdrop" class="btn btn-outline-warning">
                                <i class="bi bi-gear"></i> Configure Airdrop
                            </a>
                            <button id="btnHistorial" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#historialModal">
                                <i class="bi bi-clock-history"></i> History
                            </button>
                            <a id="btnHorizon" href="#" target="_blank" class="btn btn-outline-info" style="display:none;">
                                <i class="bi bi-link-45deg"></i> View on Horizon
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Alert Messages -->
            {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                {% for category, message in messages %}
                <div class="alert alert-{{ category }}">
                    {{ message }}
                    {% if horizon_url %}
                    <a href="{{ horizon_url }}" target="_blank" class="btn btn-sm btn-info ms-2">Ver en Horizon</a>
                    {% endif %}
                </div>
                {% endfor %}
            {% endif %}
            {% endwith %}


            <!-- Users Table -->
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-table"></i> Lista de Usuarios
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            {% if usuarios %}
                            <div class="table-responsive">
                                <table class="table table-dark table-hover table-striped mb-0 table-sm">
                                    <thead class="table-dark table-sm">
                                        <tr>
                                            <th>ID</th>
                                            <th>Nombre</th>
                                            <th>Wallet Address</th>
                                            <th>Tonkis</th>
                                            <th>% del fondo</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for usuario in usuarios %}
                                        <tr>
                                            <td class="table-id-color">
                                                <strong>{{ usuario.ID[:6] }}...{{ usuario.ID[-4:] }}</strong>
                                            </td>
                                            <td>
                                                <i class="bi bi-person-circle"></i>
                                                {{ usuario.Nombre }}
                                            </td>
                                            <td>
                                                {% if usuario.Wallet %}
                                                    <p class="table-id-color">{{ usuario.Wallet[:10] }}...{{ usuario.Wallet[-8:] }}</p>
                                                {% else %}
                                                    <span class="text-white">
                                                        <i class="bi bi-x-circle"></i> Sin wallet
                                                    </span>
                                                {% endif %}
                                            </td>
                                            <td>{{ usuario.Tonkis }}</td> 
                                            <td>{{ "%.2f"|format(usuario.porcentaje_fondo) }}%</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            {% else %}
                            <div class="text-center py-5">
                                <i class="bi bi-inbox fs-1"></i>
                                <p class="mt-3">No hay usuarios registrados</p>
                            </div>
                            {% endif %}
                        </div>
                        <div class="card-footer" style="padding: 0;">
                            <small>
                                <i class="bi bi-info-circle"></i>
                                Mostrando {{ usuarios|length }} usuario(s)
                            </small>
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </div>
</div>


<!-- Modal Historial -->
<div class="modal fade" id="historialModal" tabindex="-1" aria-labelledby="historialModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="historialModalLabel">
                <i class="bi bi-clock-history"></i> Historial de Movimientos
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
            <div id="historialContent" class="table-responsive">
            <!-- Aquí se cargará el historial vía AJAX -->
            </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const btnHorizon = document.getElementById("btnHorizon");
    {% if show_horizon_button and horizon_url %}
        btnHorizon.style.display = "inline-block";
        btnHorizon.href = "{{ horizon_url }}";
    {% endif %}
});
</script>


<script>
document.getElementById("btnHistorial").addEventListener("click", function() {
    fetch("/airdrop_history_ajax")
        .then(response => response.text())
        .then(html => {
            document.getElementById("historialContent").innerHTML = html;
        })
        .catch(err => {
            document.getElementById("historialContent").innerHTML = 
                "<div class='alert alert-danger'>Error al cargar historial</div>";
        });
});
</script>

<script>
  setTimeout(function() {
    let alerts = document.querySelectorAll('.alert');
    alerts.forEach(function(alert) {
      alert.classList.remove('show');   // quita la clase "show"
      alert.classList.add('fade');      // añade "fade" para animación
      setTimeout(() => alert.remove(), 500); // elimina el nodo después de la animación
    });
  }, 5000);
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


</body>
</html>















